{
  "framework": "nextjs",
  "buildCommand": "npm run build",
  "outputDirectory": ".next",
  "installCommand": "npm install",
  "functions": {
    "api/index.py": {
      "maxDuration": 60,
      "excludeFiles": "backend/**,node_modules/**,*.pdf,*.pyc,**/__pycache__/**"
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/index.py" }
  ]
}
